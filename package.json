{
  "name": "daegu-lms-crawler",
  "version": "1.0.0",
  "description": "대구대학교 스마트 LMS 사용자 정보 크롤러",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.lhb.lms-crawler",
    "productName": "LMS Crawler",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["portable"],
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  }
}
